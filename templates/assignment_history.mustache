{{!
    @template local_monlaututoria/assignment_history

    Chronological history of a student's assignments (most recent first).
    Does not show closure/reassignment reasons yet: local_tut_assignment has
    no such field in this phase.

    Classes required for JS: none
    Data attributes required for JS: none

    Context variables required for this template:
    * hasentries bool
    * entries array, each with: tutorname, typelabel, timestartformatted,
      timeendformatted, and status/statuslabel/statusclass/statusicon (see
      assignment_status)
    * message string - shown instead of the list when hasentries is false

    Example context (json):
    {
        "hasentries": false,
        "entries": [],
        "message": "This student has no assignment history yet."
    }
}}
<h3>{{#str}} assignment_history_title, local_monlaututoria {{/str}}</h3>
{{#hasentries}}
<ul class="list-group">
    {{#entries}}
    <li class="list-group-item">
        <div>{{tutorname}} — {{typelabel}} {{> local_monlaututoria/assignment_status}}</div>
        <div class="small text-muted">{{timestartformatted}} — {{timeendformatted}}</div>
    </li>
    {{/entries}}
</ul>
{{/hasentries}}
{{^hasentries}}
    {{> local_monlaututoria/empty_state}}
{{/hasentries}}
