{{!
    @template local_monlaututoria/assignment_summary

    One row of the assignments listing table. Included as a partial, in a
    loop, from local_monlaututoria/assignments_list.

    Classes required for JS: none
    Data attributes required for JS: none

    Context variables required for this template:
    * studentname string
    * tutorname string
    * cotutornames string - comma-separated, or a placeholder when none
    * cohortname string - or a placeholder when none
    * academicyearname string
    * typelabel string
    * timestartformatted string
    * timeendformatted string - or a placeholder while still active
    * sourcelabel string
    * detailurl string
    * viewdetaillabel string
    * studentfichaurl string
    * studentfichalabel string
    * canedit bool - whether to show the edit link
    * editurl string - only used when canedit is true
    * editlabel string - only used when canedit is true
    * canclose bool - whether to show the close link (never true for co-tutor rows)
    * closeurl string - only used when canclose is true
    * closelabel string - only used when canclose is true
    * status, statuslabel, statusclass, statusicon - see assignment_status

    Example context (json):
    {
        "studentname": "Jane Student",
        "tutorname": "John Tutor",
        "cotutornames": "—",
        "cohortname": "—",
        "academicyearname": "2026-2027",
        "typelabel": "Primary tutor",
        "timestartformatted": "1 September 2026",
        "timeendformatted": "—",
        "sourcelabel": "Manual",
        "detailurl": "https://example.org/local/monlaututoria/assignments/view.php?id=1",
        "viewdetaillabel": "View detail",
        "studentfichaurl": "https://example.org/local/monlaututoria/student/view.php?id=2",
        "studentfichalabel": "View file",
        "canedit": true,
        "editurl": "https://example.org/local/monlaututoria/assignments/edit.php?id=1",
        "editlabel": "Edit",
        "canclose": true,
        "closeurl": "https://example.org/local/monlaututoria/assignments/close.php?id=1",
        "closelabel": "Close",
        "status": "active",
        "statuslabel": "Active",
        "statusclass": "success",
        "statusicon": "check-circle"
    }
}}
<tr>
    <td>{{studentname}}</td>
    <td>{{tutorname}}</td>
    <td>{{cotutornames}}</td>
    <td>{{cohortname}}</td>
    <td>{{academicyearname}}</td>
    <td>{{typelabel}}</td>
    <td>{{timestartformatted}}</td>
    <td>{{timeendformatted}}</td>
    <td>{{> local_monlaututoria/assignment_status}}</td>
    <td>{{sourcelabel}}</td>
    <td>
        <a href="{{detailurl}}">{{viewdetaillabel}}</a>
        | <a href="{{studentfichaurl}}">{{studentfichalabel}}</a>
        {{#canedit}} | <a href="{{editurl}}">{{editlabel}}</a>{{/canedit}}
        {{#canclose}} | <a href="{{closeurl}}">{{closelabel}}</a>{{/canclose}}
    </td>
</tr>
