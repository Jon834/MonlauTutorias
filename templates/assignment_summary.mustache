{{!
    @template local_monlaututoria/assignment_summary

    One row of the assignments listing table. Included as a partial, in a
    loop, from local_monlaututoria/assignments_list.

    Classes required for JS: none
    Data attributes required for JS: none

    Context variables required for this template:
    * studentname string
    * tutorname string
    * cotutornames string - comma-separated, or a placeholder when none
    * cohortname string - or a placeholder when none
    * academicyearname string
    * typelabel string
    * timestartformatted string
    * timeendformatted string - or a placeholder while still active
    * sourcelabel string
    * detailurl string
    * viewdetaillabel string
    * status, statuslabel, statusclass, statusicon - see assignment_status

    Example context (json):
    {
        "studentname": "Jane Student",
        "tutorname": "John Tutor",
        "cotutornames": "—",
        "cohortname": "—",
        "academicyearname": "2026-2027",
        "typelabel": "Primary tutor",
        "timestartformatted": "1 September 2026",
        "timeendformatted": "—",
        "sourcelabel": "Manual",
        "detailurl": "https://example.org/local/monlaututoria/assignments/view.php?id=1",
        "viewdetaillabel": "View detail",
        "status": "active",
        "statuslabel": "Active",
        "statusclass": "success",
        "statusicon": "check-circle"
    }
}}
<tr>
    <td>{{studentname}}</td>
    <td>{{tutorname}}</td>
    <td>{{cotutornames}}</td>
    <td>{{cohortname}}</td>
    <td>{{academicyearname}}</td>
    <td>{{typelabel}}</td>
    <td>{{timestartformatted}}</td>
    <td>{{timeendformatted}}</td>
    <td>{{> local_monlaututoria/assignment_status}}</td>
    <td>{{sourcelabel}}</td>
    <td><a href="{{detailurl}}">{{viewdetaillabel}}</a></td>
</tr>
