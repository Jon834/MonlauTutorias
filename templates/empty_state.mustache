{{!
    @template local_monlaututoria/empty_state

    Generic "no results" notice, reused wherever a list/history has no rows.

    Classes required for JS: none
    Data attributes required for JS: none

    Context variables required for this template:
    * message string - already-translated message to display

    Example context (json):
    {
        "message": "No assignments have been created yet."
    }
}}
<div class="alert alert-info" role="status">{{message}}</div>
