{{!
    @template local_monlaututoria/assignment_status

    Status badge for an assignment. Always shows a text label alongside the
    icon/colour, never colour-only, so it stays understandable without
    relying on colour perception.

    Classes required for JS: none
    Data attributes required for JS: none

    Context variables required for this template:
    * status string - raw status value (active, closed, cancelled, pending, upcoming)
    * statuslabel string - translated label
    * statusclass string - Bootstrap colour suffix (success, secondary, danger, warning, info)
    * statusicon string - Font Awesome icon name (without the fa- prefix)

    Example context (json):
    {
        "status": "active",
        "statuslabel": "Active",
        "statusclass": "success",
        "statusicon": "check-circle"
    }
}}
<span class="badge badge-{{statusclass}}" data-status="{{status}}">
    <i class="icon fa fa-{{statusicon}} fa-fw" aria-hidden="true"></i> {{statuslabel}}
</span>
